Options -Indexes

# Force HTTPS (uncomment when SSL is active on Hostinger)
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]

RewriteEngine On

# Allow CSS and other static assets in includes/ to load freely
RewriteRule ^includes/.*\.(css|js|png|jpg|gif|woff|woff2)$ - [L]

# Block direct access to PHP files in includes/ folder
RewriteRule ^includes/.*\.php$ - [F,L]

# Redirect bare root to login
RewriteRule ^$ /index.php [L]

# PHP session security
php_value session.cookie_httponly 1
php_value session.use_strict_mode 1